# Supabase project settings (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed to run scripts/seed-restrooms.ts (service role key, keep secret, never NEXT_PUBLIC_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: set to gate the whole app behind HTTP Basic Auth (any username, this password).
# Leave unset to keep the app open.
APP_PASSWORD=
